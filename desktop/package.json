{
  "name": "syncwatch-desktop",
  "version": "1.0.0",
  "private": true,
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "prepare:app": "node prepare.cjs",
    "dist": "npm run prepare:app && electron-builder --win"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest"
  },
  "build": {
    "appId": "com.syncwatch.desktop",
    "productName": "SyncWatch",
    "files": [
      "main.cjs",
      "preload.cjs",
      "guest-preload.cjs",
      "package.json",
      "app/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
