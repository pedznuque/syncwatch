{
  "manifest_version": 3,
  "name": "SyncWatch Web Player",
  "version": "1.3.0",
  "description": "Synchronize HTML5 video playback through a SyncWatch room.",
  "permissions": ["storage", "tabs", "windows"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "SyncWatch Web Player",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
